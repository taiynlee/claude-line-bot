# 複製這個檔案為 .env，填入真實值
# cp .env.example .env

# ── LINE Messaging API ────────────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=填你的channel-access-token
LINE_CHANNEL_SECRET=填你的channel-secret

# ── 白名單（強烈建議設定）───────────────────────────────────────────────────
# 1對1 白名單（逗號分隔）；留空 = 不限制
ALLOWED_USER_IDS=

# 群組白名單（逗號分隔）；留空 = 不允許任何群組
ALLOWED_GROUP_IDS=

# ── Claude Code ──────────────────────────────────────────────────────────────
# WSL 內需先安裝 Claude Code：
#   curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo bash -
#   sudo apt-get install -y nodejs
#   npm install -g @anthropic-ai/claude-code
# 然後登入：claude （選 "Log in with Claude account" → 用 Pro 帳號）
#
# 若 claude 在 PATH 就保持 "claude"；找不到則填完整路徑
CLAUDE_BIN=claude

# 回應超時秒數
CLAUDE_TIMEOUT=120

# 對話歷史保留輪數（一輪 = 一問一答）
MAX_TURNS=20
